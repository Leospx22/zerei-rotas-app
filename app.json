{
  "expo": {
    "name": "Zerei Rotas",
    "slug": "zerei-rotas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zereirotas",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B1F3A",
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zereirotas.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1F3A",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.zereirotas.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "Zerei Rotas",
      "shortName": "Zerei Rotas",
      "description": "Organize, otimize e conclua suas rotas de entrega mais rápido",
      "backgroundColor": "#0B1F3A",
      "themeColor": "#102A4D",
      "orientation": "portrait",
      "startUrl": "/",
      "display": "standalone",
      "preferRelatedApplications": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d1794a60-25c0-41fa-9de9-787536d806bf"
      }
    }
  }
}
