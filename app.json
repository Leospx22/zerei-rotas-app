{
  "expo": {
    "name": "Zerei Rotas",
    "slug": "zerei-rotas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zereirotas",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A1628",
      "image": "./assets/images/icon.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zereirotas.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.zereirotas.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "Zerei Rotas",
      "shortName": "Zerei Rotas",
      "description": "Organize, otimize e conclua suas rotas de entrega mais rápido",
      "backgroundColor": "#0A1628",
      "themeColor": "#0A2572",
      "orientation": "portrait",
      "startUrl": "/",
      "display": "standalone",
      "preferRelatedApplications": true
    },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
